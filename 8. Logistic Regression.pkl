   "source": [
    "# Coefficients Interpretation\n",
    "coeff_df = pd.DataFrame({\n",
    "    \"Feature\": X.columns,\n",
    "    \"Coefficient\": model.coef_[0]\n",
    "})\n",
    "\n",
    "print(coeff_df.sort_values(by=\"Coefficient\", ascending=False)) # Sort the coefficients by descending order i.e highest value will be first therefore ascending = False"
   ]

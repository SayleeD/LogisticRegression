   ],
   "source": [
    "# Data Preprocessing\n",
    "# Handle Missing Values - in the dataset, 0 may represent missing for some columns, e.g. BMI can't 0 of a person, same goes for Insulin, Glucose.\n",
    "\n",
    "# Identify the columns which contain 0 as values except for Outcome as it has 0 - No & 1 - Yes, categorical target variable, Pregnancies - as some person might not have a child - valid situation\n",
    "print(\"Columns with zero values:\\n\",(df == 0).sum())\n",
    "\n",
    "# Replace the appropri. columns with the median values of the respective column \n",
    "# We are replacing with median as the it is robust to outliers and better than mean for skewed data\n",
    "cols_w_zero = ['Glucose', 'BloodPressure', 'SkinThickness', 'Insulin', 'BMI']\n",
    "\n",
    "for col in cols_w_zero:\n",
    "    df[col] = df[col].replace(0, np.nan) # first replace 0 values with nan values for each of the columns\n",
    "    df[col].fillna(df[col].median(), inplace = True) # replace the nan values with median, inplace = True to make permanent changes in the dataframe\n",
    "\n",
    "print(\"\\nOutlier Counts:\") # New Line character\n",
    "# Apply Outlier Detection and Treatment using IQR capping\n",
    "def detect_treat_outliers(col):\n",
    "    Q1 = df[col]. quantile(0.25)\n",
    "    Q3 = df[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    \n",
    "    LW = Q1 - (1.5 * IQR)\n",
    "    UW = Q3 + (1.5 * IQR)\n",
    "    \n",
    "    outliers = df[(df[col] < LW) | (df[col] > UW)]\n",
    "    print(f\"{col} Outliers:\", len(outliers))\n",
    "    df[col] = df[col].clip(lower=LW, upper=UW)\n",
    "\n",
    "# Apply only to numerical columns\n",
    "num_cols = df.select_dtypes(include=np.number).columns\n",
    "\n",
    "for col in num_cols:\n",
    "    detect_treat_outliers(col)\n"
   ]
  },

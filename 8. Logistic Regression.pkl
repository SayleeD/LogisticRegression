    "# Import the Model Building Libraries\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "# Import the Model Evaluation Libraries\n",
    "from sklearn.metrics import confusion_matrix, accuracy_score, precision_score, recall_score, f1_score, roc_auc_score, roc_curve # Additionally, I have considered Confusion Matrix\n",
    "\n",
    "# Load the dataset using pandas library and convert it into the data frame\n",
    "df = pd.read_csv(\"diabetes.csv\")\n",
    "df.head() # to read the first 5 rows along with column and their respective values"
   ]
